APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_API_BASE_URL=https://ride-share-app-production-ab31.up.railway.app

# Database Configuration
# Local example:
# DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost/rideshare_db
#
# Railway public host example for local development:
# DATABASE_URL=mysql+pymysql://MYSQLUSER:MYSQLPASSWORD@shuttle.proxy.rlwy.net:PORT/MYSQLDATABASE
#
# Railway internal host example for a backend deployed on Railway:
# DATABASE_URL=mysql+pymysql://MYSQLUSER:MYSQLPASSWORD@mysql.railway.internal:3306/MYSQLDATABASE
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost/rideshare_db

# Authentication Configuration
# Use a strong random string for SECRET_KEY
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration for OTPs
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
# Use the Gmail app password without spaces, for example: abcdwxyzefghijkl
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@example.com
